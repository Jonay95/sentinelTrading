FLASK_APP=wsgi:app
FLASK_ENV=development
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///sentinel.db

# Opcional: Finnhub (noticias por ticker)
FINNHUB_API_KEY=
# Opcional: NewsAPI (búsqueda por keywords)
NEWS_API_KEY=

# CORS: origen del frontend Vite
CORS_ORIGINS=http://localhost:5173

# Versión del modelo (A/B entre baseline-v1, enhanced-v1, etc.)
MODEL_VERSION=enhanced-v1

# Horizonte de la predicción en días
HORIZON_DAYS=1
# Umbral mínimo de señal; el efectivo es max(THRESHOLD_BASE_PCT, VOL_THRESHOLD_MULTIPLIER * vol_20d_logret)
THRESHOLD_BASE_PCT=0.003
VOL_THRESHOLD_MULTIPLIER=0.65
THRESHOLD_MAX_PCT=0.045
# Media ARIMA + ETS con suficiente historia
PRED_ENSEMBLE=1
# Ajuste direccional leve según momentum 5d (0 = desactivado)
MOMENTUM_BLEND=0.12
# Penalización de confianza si volatilidad extrema
HIGH_VOL_CONFIDENCE_PENALTY=0.88

# Ingesta: días CoinGecko (máx. 365 en diario) y periodo yfinance (ej. 1y, 2y, max)
COINGECKO_DAYS=365
YFINANCE_PERIOD=2y

# Noticias: no volver a llamar a la API si ya hubo ingesta en las últimas N horas (0 = siempre pedir)
NEWS_MIN_INTERVAL_HOURS=8
NEWS_PAGE_SIZE=12
